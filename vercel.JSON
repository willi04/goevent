{
  "version": 2,
  "builds": [
    {
      "src": "web/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/e/(?<slug>[a-zA-Z0-9]+)",
      "dest": "/web/event_detail.html?slug=$slug"
    },
    {
      "src": "/(.*)",
      "dest": "/web/$1"
    }
  ]
}
