{
  "version": 2,
  "builds": [
    {
      "src": "web/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/e/([a-zA-Z0-9]+)/?$",
      "dest": "/web/event_detail.html?slug=$1"
    },
    {
      "src": "^/(.*)",
      "dest": "/web/$1"
    }
  ]
}
